APP_NAME=SIM_POSYANDU
APP_ENV=production
APP_DEBUG=true
APP_URL=https://sim-posyandu.vercel.app

LOG_CHANNEL=stderr
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=mysql-13bc21ec-ssuprapto351-4e57.c.aivencloud.com
DB_PORT=26428
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=PASSWORD_AIVEN_KAMU
MYSQL_ATTR_SSL_CA=config/certs/aiven-ca.pem
MYSQL_ATTR_SSL_VERIFY_SERVER_CERT=false

CACHE_STORE=array
CACHE_DRIVER=array
QUEUE_CONNECTION=sync

SESSION_DRIVER=database
SESSION_CONNECTION=mysql
SESSION_TABLE=sessions
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_COOKIE=sim_posyandu_session

APP_STORAGE=/tmp/storage
VIEW_COMPILED_PATH=/tmp/views